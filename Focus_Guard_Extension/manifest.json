{
  "manifest_version": 3,
  "name": "Focus Guard",
  "version": "1.0",
  "description": "Reduce distractions by blocking social media and removing YouTube Shorts",
  
  "permissions": ["storage"],
  
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}